# ============================================================
# FLUX.2-klein-9B 推理服务 环境变量
# ============================================================
# 复制为 .env 后修改对应值

# ── 模型来源 ──────────────────────────────────────────
# 模型 ID
FLUX_MODEL_ID=black-forest-labs/FLUX.2-klein-9B

# 模型来源：huggingface | modelscope | local
FLUX_MODEL_SOURCE=modelscope

# 本地模型路径（FLUX_MODEL_SOURCE=local 时使用）
# FLUX_MODEL_PATH=/data/models/FLUX.2-klein-9B

# ModelScope 缓存目录
MODELSCOPE_CACHE=./models

# ── HuggingFace 镜像（国内加速）──────────────────────
# 使用 hf-mirror.com 镜像下载模型
HF_ENDPOINT=https://hf-mirror.com

# HuggingFace 缓存
HF_HOME=./cache/huggingface

# HuggingFace Token（下载需要授权的模型）
# HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxx

# ── 服务配置 ──────────────────────────────────────────
FLUX_HOST=0.0.0.0
FLUX_PORT=5500
FLUX_DEVICE=cuda

# ── 显存优化 ──────────────────────────────────────────
# 启用 CPU Offload（显存 < 24GB 时建议开启）
FLUX_CPU_OFFLOAD=false

# 最大并发推理数（L20 48GB 建议 1，双卡可设 2）
FLUX_MAX_CONCURRENT=1

# ── API 鉴权（可选，内网部署建议留空）───────────────
# FLUX_API_KEY=your-secret-key

# ── 图片存储（可选）──────────────────────────────────
# FLUX_IMAGE_STORAGE=/data/flux-images
